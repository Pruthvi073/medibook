# ============================================================
# MediBook Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── JWT Authentication ───────────────────────────────────────
# Use a long, random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ── MongoDB Database ──────────────────────────────────────────
# Local MongoDB:  mongodb://localhost:27017/medibook
# MongoDB Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/medibook
MONGODB_URI=mongodb://localhost:27017/medibook

# ── Flask ML Service ─────────────────────────────────────────
ML_SERVICE_URL=http://localhost:5001

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173
