# ============================================================
# MediBook Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── JWT Authentication ───────────────────────────────────────
# Use a long, random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# -- MongoDB Database -----------------------------------------
# Local:  mongodb://localhost:27017/medibook
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/medibook
MONGODB_URI=mongodb://localhost:27017/medibook

# ── Flask ML Service ─────────────────────────────────────────
ML_SERVICE_URL=http://localhost:5001

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Google Gemini AI (Medical Report Analysis) ────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/min, 1500 requests/day — sufficient for dev
GEMINI_API_KEY=your_gemini_api_key_here
